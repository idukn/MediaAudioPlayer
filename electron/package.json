{
  "name": "media-audio-finder",
  "version": "1.0.0",
  "description": "Desktop app for searching videos and saving audio with yt-dlp",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:app": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "local.media.audio.finder",
    "productName": "Media Audio Finder",
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.music"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "electron-store": "^10.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
