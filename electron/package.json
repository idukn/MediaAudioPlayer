{
  "name": "media-audio-finder",
  "version": "1.0.0",
  "description": "Desktop app for searching videos and saving audio with yt-dlp",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --dir",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win portable --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:desktop": "node scripts/build-desktop.js"
  },
  "build": {
    "appId": "local.media.audio.finder",
    "productName": "Media Audio Finder",
    "asar": true,
    "mac": {
      "target": ["dir"],
      "category": "public.app-category.music"
    },
    "win": {
      "target": ["nsis", "portable"],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Audio"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": []
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "electron-store": "^10.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
