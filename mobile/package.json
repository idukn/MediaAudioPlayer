{
  "name": "media-audio-finder-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Media Audio Finder for Android",
  "scripts": {
    "sync:www": "node scripts/sync-www.mjs",
    "cap:sync": "npm run sync:www && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run cap:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/clipboard": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/dialog": "^7.0.1",
    "@capacitor/filesystem": "^7.1.1",
    "media-audio-finder-plugin": "file:./plugins/media-audio-finder"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "typescript": "^5.8.2"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  }
}
