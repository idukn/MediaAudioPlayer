<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <queries>
        <package android:name="com.android.virtualization.terminal" />
        <intent>
            <action android:name="android.virtualization.VM_TERMINAL" />
        </intent>
    </queries>

    <application
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <service
            android:name="local.media.audio.finder.PlaybackForegroundService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="mediaPlayback" />

        <receiver
            android:name="local.media.audio.finder.PlaybackControlReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="local.media.audio.finder.PREV" />
                <action android:name="local.media.audio.finder.NEXT" />
                <action android:name="local.media.audio.finder.PLAY_PAUSE" />
                <action android:name="local.media.audio.finder.CYCLE_LOOP" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
